# =============================================================================
# Bakery Management — Environment Variables
# HƯỚNG DẪN: Copy file này thành ".env", sau đó đổi mật khẩu.
# File .env KHÔNG được commit lên Git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=bakery_db
DB_USER=bakery
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8080

# ── Thư mục batch (để mặc định, không cần đổi) ────────────────────────────────
BATCH_INPUT_DIR=/app/batch-input
BATCH_OUTPUT_DIR=/app/batch-output
